source "https://rubygems.org"

# Use the github-pages gem so local builds match what GitHub Pages runs.
gem "github-pages", group: :jekyll_plugins

# Tzinfo data for Windows/JRuby; harmless elsewhere.
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]

# Faster file watching during `jekyll serve`.
gem "wdm", "~> 0.1", platforms: [:mingw, :mswin, :x64_mingw]
